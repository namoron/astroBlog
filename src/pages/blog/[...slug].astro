---
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getPosts, type PostWithSource } from '../../lib/content';

export async function getStaticPaths() {
	const posts = await getPosts('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = PostWithSource<'blog'>;

const post = Astro.props;
const rendered = post.source === 'local' ? await render(post.entry) : undefined;
---

<BlogPost title={post.title} description={post.description} pubDate={post.pubDate} updatedDate={post.updatedDate} heroImage={post.heroImage}>
	{post.source === 'local' && rendered && <rendered.Content />}
	{post.source === 'microcms' && <Fragment set:html={post.content} />}
</BlogPost>
