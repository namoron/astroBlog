---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';
import { getPosts } from '../../lib/content';

const posts = await getPosts('work');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul >
					{
						posts.map((post) => (
							<li  class="px-0 py-2">
								<a  id="workLi"class="block rounded-lg overflow-hidden shadow-md hover:shadow-lg transition duration-300  flex flex-col justify-center items-center" href={`/work/${post.slug}/`}>
									{post.heroImage && <img class="mt-6"  width={10} height={10} src={post.heroImage} alt="" />}
									<h4 class="text-xl mb-1 mt-1">{post.title}</h4>
									<p class="text-gray-600">
										<FormattedDate date={post.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
